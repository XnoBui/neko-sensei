# ── Neko Sensei — nginx location blocks ──
# Paste inside the server {} block of /etc/nginx/sites-enabled/default-server
# App runs at /neko-sensei/ on the shared VPS (89.167.23.147).

# API → Node.js (streams, longer timeout for Claude calls)
location /neko-sensei/api/ {
    proxy_pass http://127.0.0.1:3500/neko-sensei/api/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 120s;
    proxy_buffering off;
}

# App (static + SSR)
location /neko-sensei/ {
    proxy_pass http://127.0.0.1:3500/neko-sensei/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

location = /neko-sensei {
    return 301 /neko-sensei/;
}
